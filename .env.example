# Railway Postgres (required for agent registration)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Public URL of your deployment (set in Railway variables)
PUBLIC_URL=https://your-app.up.railway.app

# Secret pepper for API key hashing (generate a long random string)
KEYMINT_PEPPER=change-me-to-a-long-random-string

PORT=3000
